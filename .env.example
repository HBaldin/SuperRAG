# SuperRAG — Variáveis de ambiente de exemplo
# Copie para .env e ajuste conforme necessário

# Caminho do repositório no host a ser indexado
REPO_PATH=/caminho/do/seu/projeto

# Porta da API no host (padrão: 3000)
API_PORT=3000

# Indexação automática ao iniciar o container (true/false)
AUTO_INDEX=true

# Ativa file watcher para indexação incremental (true/false)
WATCH_ENABLED=true

# Nível de log (debug | info | warn | error)
RAG_LOG_LEVEL=info
